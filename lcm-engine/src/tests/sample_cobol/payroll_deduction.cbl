       IDENTIFICATION DIVISION.
       PROGRAM-ID. PAYROLL-DEDUCTION.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01  WS-GROSS-PAY          PIC 9(7)V99 VALUE 5000.00.
       01  WS-TAX-RATE           PIC 9(1)V99 VALUE 0.15.
       01  WS-INSURANCE-RATE     PIC 9(1)V99 VALUE 0.05.
       01  WS-TAX-DEDUCTION      PIC 9(7)V99.
       01  WS-INSURANCE-DEDUCTION PIC 9(7)V99.
       01  WS-TOTAL-DEDUCTION    PIC 9(7)V99.
       01  WS-NET-PAY            PIC 9(7)V99.
       
       PROCEDURE DIVISION.
       MAIN-LOGIC.
           COMPUTE WS-TAX-DEDUCTION = WS-GROSS-PAY * WS-TAX-RATE
           COMPUTE WS-INSURANCE-DEDUCTION = WS-GROSS-PAY * WS-INSURANCE-RATE
           COMPUTE WS-TOTAL-DEDUCTION = WS-TAX-DEDUCTION + WS-INSURANCE-DEDUCTION
           COMPUTE WS-NET-PAY = WS-GROSS-PAY - WS-TOTAL-DEDUCTION
           
           DISPLAY "Gross Pay: $" WS-GROSS-PAY
           DISPLAY "Net Pay after deductions: $" WS-NET-PAY
           
           STOP RUN.
